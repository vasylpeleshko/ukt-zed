{
  "name": "ukt-zed",
  "version": "1.0.0",
  "description": "AI-система для автоматичного визначення коду УКТ ЗЕД",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:migrate": "prisma migrate deploy && node dist/main",
    "cli": "nest build && node dist/cli/main.js",

    "parse:pdf": "tsx scripts/parse-pdf.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "data:reload": "npm run db:migrate:deploy && tsx scripts/parse-pdf.ts && tsx prisma/seed.ts && tsx scripts/enrich-context.ts --reembed && tsx scripts/generate-embeddings.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "context:enrich": "tsx scripts/enrich-context.ts",
    "embeddings:setup": "tsx scripts/setup-pgvector.ts",
    "phase2.1": "tsx scripts/enrich-context.ts --reembed && tsx scripts/generate-embeddings.ts",
    "embeddings:generate": "tsx scripts/setup-pgvector.ts && tsx scripts/generate-embeddings.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "license": "ISC",
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.4.2",
    "nest-commander": "^3.20.1",
    "openai": "^5.10.1",
    "pdf-parse": "^1.1.1",
    "prisma": "^6.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.1.3",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.14",
    "@types/supertest": "^7.2.1",
    "jest": "^30.0.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3"
  }
}
